---
import { HomeTerminal } from '../components/HomeTerminal'
import HomeLayout from '../layouts/HomeLayout.astro'

const title = 'Abraham Galindo | Staff Software Engineer'
const description =
  'Abraham Galindo is a Staff Software Engineer focused on React, Next.js, Node.js, TypeScript, micro-frontends, frontend architecture, and product delivery.'
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Abraham Galindo',
  url: 'https://abrahamgr.dev/',
  email: 'mailto:contact@abrahamgr.dev',
  jobTitle: 'Staff Software Engineer',
  description,
  knowsAbout: [
    'React',
    'Next.js',
    'Node.js',
    'TypeScript',
    'Micro-frontends',
    'Frontend architecture',
    'Cloudflare Workers',
    'Web performance',
    'Design systems',
    'Technical leadership',
  ],
  sameAs: [
    'https://github.com/abrahamgr',
    'https://www.linkedin.com/in/abrahamgr28',
    'https://www.credly.com/users/abrahamgr/badges',
  ],
}
---

<HomeLayout
	title={title}
	description={description}
	canonicalPath="/"
	keywords={[
		'Abraham Galindo',
		'Staff Software Engineer',
		'React',
		'Next.js',
		'Node.js',
		'TypeScript',
		'micro-frontends',
		'frontend architecture',
		'Cloudflare Workers',
		'web performance',
		'technical leadership',
	]}
	structuredData={structuredData}
>
	<HomeTerminal />
</HomeLayout>

<script>
	document.addEventListener('keydown', (event) => {
		if (event.altKey || event.ctrlKey || event.metaKey || event.isComposing) {
			return
		}

		const target = event.target

		if (
			target instanceof HTMLElement &&
			(target.isContentEditable ||
				['INPUT', 'SELECT', 'TEXTAREA'].includes(target.tagName))
		) {
			return
		}

		const link = document.querySelector<HTMLAnchorElement>(
			`[data-terminal-shortcut="${event.key}"]`,
		)

		if (!link) {
			return
		}

		event.preventDefault()

		window.posthog?.capture('keyboard_shortcut_used', {
			shortcut_key: event.key,
			link_label: link.textContent?.trim() ?? '',
			link_href: link.href,
		})

		if (link.href.startsWith('mailto:')) {
			window.location.href = link.href
			return
		}

		window.open(link.href, '_blank', 'noopener,noreferrer')
	})
</script>
